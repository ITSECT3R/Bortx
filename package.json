{
  "name": "bortx",
  "version": "0.1.0",
  "description": "Open-source CSS border and text animation library",
  "license": "MIT",
  "author": "Bortx Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ITSECT3R/Bortx.git"
  },
  "homepage": "https://github.com/ITSECT3R/Bortx#readme",
  "keywords": [
    "css",
    "animation",
    "border",
    "text",
    "css-animations",
    "border-effects",
    "text-effects",
    "react",
    "typescript",
    "css-library",
    "frontend",
    "ui-effects"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./borders": {
      "types": "./dist/borders/index.d.ts",
      "import": "./dist/borders/index.js"
    },
    "./borders/styles": "./dist/borders/base.css",
    "./text": {
      "types": "./dist/text/index.d.ts",
      "import": "./dist/text/index.js"
    },
    "./text/styles": "./dist/text/base.css",
    "./react": {
      "types": "./dist/react/hooks/index.d.ts",
      "import": "./dist/react/hooks/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "*.css",
    "src/**/index.ts"
  ],
  "scripts": {
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "build": "tsup"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.8"
  }
}
